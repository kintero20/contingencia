# Base de datos (SQLite por defecto para desarrollo)
# DATABASE_URL=sqlite+aiosqlite:///./sbeup.db
# DATABASE_URL_SYNC=sqlite:///./sbeup.db

# Para produccion con PostgreSQL + pgvector:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sbeup
# DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/sbeup

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# CORS
CORS_ORIGINS=["*"]

# Uploads
UPLOAD_DIR=uploads
